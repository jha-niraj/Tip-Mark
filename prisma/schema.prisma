generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    SUPPORTER
    CREATOR
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    role      UserRole @default(SUPPORTER)
    createdAt DateTime @default(now())

    @@map("users")
}

model Otp {
    id        String   @id @default(cuid())
    email     String
    code      String
    used      Boolean  @default(false)
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@index([email])
    @@map("otps")
}

model Creator {
    id        Int      @id @default(autoincrement())
    wallet    String   @unique
    username  String   @unique
    name      String?
    bio       String?
    avatarUrl String?
    createdAt DateTime @default(now())

    tips Tip[]

    @@map("creators")
}

model Tip {
    id        Int      @id @default(autoincrement())
    txHash    String   @unique
    tipper    String
    creatorId Int
    amountSol Decimal  @db.Decimal(18, 9)
    message   String?
    badgeTier String?
    nftMint   String?
    createdAt DateTime @default(now())

    creator Creator @relation(fields: [creatorId], references: [id])

    @@index([tipper])
    @@index([creatorId])
    @@map("tips")
}
