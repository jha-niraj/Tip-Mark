generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    SUPPORTER
    CREATOR
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    role      UserRole @default(SUPPORTER)
    createdAt DateTime @default(now())

    creatorProfile CreatorProfile?
    tipsSent       Tip[]           @relation("SupporterTips")

    @@map("users")
}

model Otp {
    id        String   @id @default(cuid())
    email     String
    code      String
    used      Boolean  @default(false)
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@index([email])
    @@map("otps")
}

/// Single creator identity: public page, **Solana** receive address, and **Stripe Connect** payout state.
model CreatorProfile {
    id     String @id @default(cuid())
    userId String @unique
    /// Public URL segment, e.g. `/u/[slug]`
    slug   String @unique

    displayName String?
    bio         String?
    avatarUrl   String?

    /// Primary Solana wallet that receives SOL tips (optional until linked).
    solanaWallet String? @unique

    /// Stripe Connect / Express account for card tips & campaign tips.
    stripeConnectAccountId String?
    stripeChargesEnabled   Boolean @default(false)
    stripeDetailsSubmitted Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    campaigns Campaign[]
    tips      Tip[]      @relation("TipsToCreator")

    @@map("creator_profiles")
}

enum CampaignStatus {
    ACTIVE
    PAUSED
    ENDED
}

model Campaign {
    id               String         @id @default(cuid())
    creatorProfileId String
    title            String
    description      String?
    goalAmountCents  Int?
    status           CampaignStatus @default(ACTIVE)
    endsAt           DateTime?
    createdAt        DateTime       @default(now())
    updatedAt        DateTime       @updatedAt

    creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
    tips           Tip[]

    @@index([creatorProfileId])
    @@map("campaigns")
}

/// How this tip was settled: on-chain SOL or card via Stripe.
enum TipRail {
    SOLANA
    STRIPE
}

enum TipStatus {
    PENDING
    SUCCEEDED
    FAILED
    CANCELED
}

/// One ledger row per tip — **Solana** and **Stripe** share this model; use `rail` + the relevant fields.
model Tip {
    id String @id @default(cuid())

    rail             TipRail
    creatorProfileId String
    /// App user who tipped (optional for anonymous / wallet-only flows).
    supporterUserId  String?
    /// Card tips may target a campaign; SOL tips usually leave this null.
    campaignId       String?

    // ——— Solana (rail = SOLANA) ———
    /// Transaction signature (unique when present).
    solanaSignature String?  @unique
    /// Tipper wallet address on Solana when not linked to a User.
    tipperWallet    String?
    amountSol       Decimal? @db.Decimal(18, 9)

    // ——— Stripe (rail = STRIPE) ———
    amountCents             Int?
    currency                String? @default("usd")
    stripePaymentIntentId   String? @unique
    stripeCheckoutSessionId String? @unique

    // ——— Shared ———
    message   String?
    badgeTier String?
    nftMint   String?

    status    TipStatus @default(PENDING)
    createdAt DateTime  @default(now())

    creatorProfile CreatorProfile @relation("TipsToCreator", fields: [creatorProfileId], references: [id], onDelete: Cascade)
    campaign       Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
    supporter      User?          @relation("SupporterTips", fields: [supporterUserId], references: [id], onDelete: SetNull)

    @@index([creatorProfileId])
    @@index([supporterUserId])
    @@index([rail])
    @@map("tips")
}
